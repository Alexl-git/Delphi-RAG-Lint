<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
        <ProjectVersion>19.5</ProjectVersion>
        <FrameworkType>None</FrameworkType>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <TargetedPlatforms>1</TargetedPlatforms>
        <AppType>Package</AppType>
        <MainSource>dclDragLintWizard.dpk</MainSource>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
        <DCC_BplOutput>..\..\build\v021</DCC_BplOutput>
        <DCC_DcpOutput>..\..\build\v021</DCC_DcpOutput>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;System.Win;$(DCC_Namespace)</DCC_Namespace>
        <SanitizedProjectName>dclDragLintWizard</SanitizedProjectName>
        <GenDll>true</GenDll>
        <GenPackage>true</GenPackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64)'!=''">
        <DCC_UsePackage>rtl;vcl;designide;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>DESIGNONLY;DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_DebugDCUs>true</DCC_DebugDCUs>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
        <DCC_DebugInfoInExe>true</DCC_DebugInfoInExe>
        <DCC_IntegerOverflowCheck>true</DCC_IntegerOverflowCheck>
        <DCC_RangeChecking>true</DCC_RangeChecking>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_Define>DESIGNONLY;RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'!=''">
        <DCC_UnitSearchPath>..\..\;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <DCC_Description>drag-lint Delphi IDE wizard (v0.21)</DCC_Description>
        <DCC_DependencyCheckOutputName>..\..\build\v021\dclDragLintWizard.bpl</DCC_DependencyCheckOutputName>
        <DCC_OutputDcpDir>..\..\build\v021</DCC_OutputDcpDir>
        <RuntimeOnlyPackage>false</RuntimeOnlyPackage>
        <DesignOnlyPackage>true</DesignOnlyPackage>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="DragLint.Plugin.Wizard.pas"/>
        <DCCReference Include="DragLint.Plugin.LspClient.pas"/>
        <DCCReference Include="DragLint.Plugin.Editor.pas"/>
        <DCCReference Include="DragLint.Plugin.ProjectNotifier.pas"/>
        <DCCReference Include="DragLint.Plugin.Settings.pas"/>
        <DCCReference Include="DragLint.Plugin.SettingsForm.pas"/>
        <DCCReference Include="DragLint.Plugin.Keyboard.pas"/>
        <DCCReference Include="DragLint.Plugin.HoverForm.pas"/>
        <DCCReference Include="DragLint.Plugin.CompletionForm.pas"/>
        <DCCReference Include="DragLint.Plugin.SignatureForm.pas"/>
        <DCCReference Include="DragLint.Plugin.SaveNotifier.pas"/>
        <DCCReference Include="DragLint.Plugin.RefactorForm.pas"/>
        <DCCReference Include="DragLint.Plugin.RegistryColors.pas"/>
        <DCCReference Include="DragLint.Plugin.DiagnosticCache.pas"/>
        <DCCReference Include="DragLint.Plugin.CodeLensCache.pas"/>
        <DCCReference Include="DragLint.Plugin.EditViewNotifier.pas"/>
        <DCCReference Include="DragLint.Plugin.StructureCache.pas"/>
        <DCCReference Include="DragLint.Plugin.StructureForm.pas"/>
        <DCCReference Include="DragLint.Plugin.OptionsFrame.pas"/>
        <DCCReference Include="DragLint.Plugin.Options.pas"/>
        <DCCReference Include="DragLint.Plugin.UsagesForm.pas"/>
        <DCCReference Include="DragLint.Plugin.SymbolSearchForm.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Package</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">dclDragLintWizard.dpk</Source>
                </Source>
                <Packages>
                    <Package Name="rtl">rtl</Package>
                    <Package Name="vcl">vcl</Package>
                    <Package Name="designide">designide</Package>
                </Packages>
            </Delphi.Personality>
        </BorlandProject>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
